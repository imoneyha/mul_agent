{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task",
  "type": "object",
  "required": ["task_id", "task_type", "goal", "constraints", "state"],
  "properties": {
    "task_id": {"type": "string"},
    "task_type": {"type": "string", "enum": ["coding", "podcast", "comic"]},
    "goal": {"type": "string"},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "inputs": {"type": "object"},
    "outputs": {"type": "object"},
    "state": {"type": "string"},
    "history": {"type": "array", "items": {"type": "object"}}
  }
}
