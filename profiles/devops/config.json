{
  "name": "mul-agent-devops",
  "port": 8083,
  "model": "npi/gpt-5.3-codex",
  
  "channels": {
    "api": {
      "enabled": true,
      "type": "http"
    }
  },
  
  "agents": {
    "developer": {
      "model": "npi/gpt-5.3-codex",
      "tools": ["read", "write", "edit", "exec", "web_search"],
      "permissions": {
        "external": false,
        "code": true,
        "shell": true
      },
      "workdir": "~/project"
    },
    "operator": {
      "model": "npi/gpt-5.3-codex",
      "tools": ["read", "exec"],
      "permissions": {
        "external": false,
        "code": true,
        "shell": true
      }
    },
    "qa": {
      "model": "npi/gpt-5.3-codex",
      "tools": ["read", "exec", "web_search"],
      "permissions": {
        "external": false,
        "code": true
      }
    }
  },
  
  "bindings": {
    "api": {
      "default": "developer",
      "rules": [
        {
          "match": ".*部署.*|.*运维.*|.*启动.*|.*停止.*",
          "agent": "operator"
        },
        {
          "match": ".*测试.*|.*验证.*|.*检查.*",
          "agent": "qa"
        }
      ]
    }
  },
  
  "report_to": "http://localhost:8080"
}
