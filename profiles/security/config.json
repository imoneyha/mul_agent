{
  "name": "mul-agent-security",
  "port": 8081,
  "model": "npi/gpt-5.3-codex",
  
  "channels": {
    "api": {
      "enabled": true,
      "type": "http"
    }
  },
  
  "agents": {
    "rescue": {
      "model": "npi/gpt-5.3-codex",
      "tools": ["read", "exec", "web_search"],
      "permissions": {
        "external": true,
        "code": true,
        "shell": true
      }
    },
    "monitor": {
      "model": "npi/gpt-5.3-codex",
      "tools": ["read", "exec"],
      "permissions": {
        "external": false,
        "code": true,
        "shell": true
      }
    },
    "audit": {
      "model": "npi/gpt-5.3-codex",
      "tools": ["read", "exec"],
      "permissions": {
        "external": false,
        "code": true,
        "shell": true
      }
    }
  },
  
  "bindings": {
    "api": {
      "default": "rescue",
      "rules": [
        {
          "match": ".*监控.*|.*状态.*|.*巡检.*",
          "agent": "monitor"
        },
        {
          "match": ".*审计.*|.*扫描.*|.*检查.*",
          "agent": "audit"
        }
      ]
    }
  },
  
  "report_to": "http://localhost:8080"
}
